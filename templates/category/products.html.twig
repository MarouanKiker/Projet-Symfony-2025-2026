{% extends 'base.html.twig' %}

{% block title %}Produits - {{ category.name }}{% endblock %}

{% block body %}
<h1 class="mb-4">Produits dans la catégorie : {{ category.name }}</h1>
<!-- Breadcrumb -->
<div class="mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_category_browse') }}" class="text-decoration-none">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ category.name }}</li>
        </ol>
    </nav>
</div>

<!-- Jumbotron -->
<div class="my-4">
    <div class="p-5 mb-4 bg-primary bg-gradient text-white rounded-3">
        <div class="container-fluid py-3">
            <h1 class="display-4 fw-bold">{{ category.name }}</h1>
            <p class="col-md-8 fs-5">Discover the best products in {{ category.name }}. Find everything you need to stay connected and entertained.</p>
            <span class="badge bg-light text-dark fs-6">{{ products|length }} Products Available</span>
        </div>
    </div>
</div>

<!-- Products Section -->
<div class="mb-5">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h3>Browse {{ category.name }}</h3>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
            <div class="col">
                <div class="card h-100">
                    <img src="{{ asset(product.image ?? 'item.png') }}" class="card-img-top" alt="{{ product.name }}">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">{{ category.name }}</span>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text fw-bold text-success">{{ product.price }} €</p>
                        <a href="{{ path('app_product_details', {id: product.id}) }}" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <p class="text-center py-5">No products found in this category.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
