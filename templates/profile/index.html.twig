{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <img src="{{ asset('profile.png') }}" class="rounded-circle mb-3" alt="User Avatar" width="120" height="120" style="object-fit: cover;">
                    <h5 class="card-title">{{ app.user.userIdentifier }}</h5>
                    <p class="text-muted">{{ app.user.email }}</p>
                    <hr>
                    <ul class="list-unstyled text-start ps-3">
                        <li class="mb-2"><a href="#profile" class="text-decoration-none"><i class="bi bi-person me-2"></i>Profile Information</a></li>
                        <li class="mb-2"><a href="#orders" class="text-decoration-none"><i class="bi bi-bag me-2"></i>My Orders</a></li>
                        <li class="mb-2"><a href="{{ path('app_logout') }}" class="text-decoration-none text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <!-- Profile Information -->
            <div class="card mb-4 shadow-sm" id="profile">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Profile Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold text-muted small">Username:</label>
                            <p class="fs-5">{{ app.user.userIdentifier }}</p>
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold text-muted small">Email Address:</label>
                            <p class="fs-5">{{ app.user.email }}</p>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold text-muted small">Account Type:</label>
                            <p><span class="badge bg-info text-dark">Standard User</span></p>
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold text-muted small">User ID:</label>
                            <p>#{{ app.user.id }}</p>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary" disabled>Edit Profile</button>
                </div>
            </div>

            <!-- Order History (Placeholder) -->
            <div class="card shadow-sm" id="orders">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Order History</h5>
                </div>
                <div class="card-body">
                    <div class="text-center py-5">
                        <p class="text-muted mb-0">You haven't placed any orders yet.</p>
                        <a href="{{ path('app_home') }}" class="btn btn-primary mt-3">Start Shopping</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
