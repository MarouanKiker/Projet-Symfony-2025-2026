{% extends 'base.html.twig' %}

{% block title %}Accueil - Our Store{% endblock %}

{% block body %}
<div class="my-5">
    <h1 class="mb-4">Our Products</h1>
    
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% if products is defined and products|length > 0 %}
            {% for product in products %}
                <div class="col">
                    <div class="card h-100">
                        <img src="{{ asset(product.image ?? 'item.png') }}" class="card-img-top" alt="{{ product.name }}">
                        <div class="card-body">
                            <span class="badge bg-primary mb-2">{{ product.category.name }}</span>
                            <h5 class="card-title">{{ product.name }}</h5>
                            <p class="card-text fw-bold text-success">{{ product.price }} €</p>
                            <a href="{{ path('app_product_details', {id: product.id}) }}" class="btn btn-outline-primary">View Details</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <!-- Fallback with static content from prof if no products in DB yet -->
            <div class="col">
                <div class="card h-100">
                    <img src="{{ asset('item.png') }}" class="card-img-top" alt="Product 1">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">Electronics</span>
                        <h5 class="card-title">Wireless Headphones</h5>
                        <p class="card-text fw-bold text-success">79.99 €</p>
                        <a href="#" class="btn btn-outline-primary disabled">View Details</a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100">
                    <img src="{{ asset('item.png') }}" class="card-img-top" alt="Product 2">
                    <div class="card-body">
                        <span class="badge bg-warning mb-2">Fashion</span>
                        <h5 class="card-title">Classic Leather Jacket</h5>
                        <p class="card-text fw-bold text-success">149.99 €</p>
                        <a href="#" class="btn btn-outline-primary disabled">View Details</a>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
