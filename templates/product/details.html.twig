{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Our Store{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-6">
        {% if product.image %}
            <img src="{{ asset(product.image) }}" class="img-fluid rounded" alt="{{ product.name }}">
        {% else %}
            <img src="https://via.placeholder.com/400" class="img-fluid rounded" alt="Placeholder">
        {% endif %}
    </div>
    <div class="col-md-6">
        <h1>{{ product.name }}</h1>
        <p class="text-muted">Catégorie: {{ product.category.name }}</p>
        <h2 class="text-success mb-4">{{ product.price }} €</h2>
        <p>{{ product.description }}</p>
        
        <form action="{{ path('app_cart_add', {id: product.id}) }}" method="POST">
            <button type="submit" class="btn btn-primary btn-lg mt-3">Ajouter au panier</button>
        </form>
    </div>
</div>
{% endblock %}
